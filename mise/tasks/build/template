#!/usr/bin/env bash
# [MISE] description="Compile template/main.typ to PDF for local preview"
#
# Since @preview/scholarly-kit:0.1.0 is not yet published, we create a
# temporary package-path directory that maps preview/scholarly-kit/0.1.0
# to the project root. This is equivalent to what tytanic does internally
# for the @template test.
set -euo pipefail

PKG_DIR=$(mktemp -d)
mkdir -p "$PKG_DIR/preview/scholarly-kit"
ln -s "$PWD" "$PKG_DIR/preview/scholarly-kit/0.1.0"

typst compile \
    --package-path "$PKG_DIR" \
    --root template \
    --font-path fonts \
    template/main.typ \
    template/main.pdf

rm -rf "$PKG_DIR"
echo "  → template/main.pdf"
