#table(
    columns: (2cm, 1fr),
    stroke: none,
    inset: (y: 4pt),
    [$bold(x)$], [State vector],
    [$bold(u)$], [Input vector],
    [$bold(y)$], [Output vector],
    [$A$], [System matrix],
    [$B$], [Input matrix],
    [$C$], [Output matrix],
    [$t$], [Time, $t in RR$],
    [$Delta t$], [Sampling interval],
)
